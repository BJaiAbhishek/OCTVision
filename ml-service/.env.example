# Copy your model here, or set this to its absolute path.
MODEL_PATH=models/vggres_best.h5
# Must match the model's training pipeline.
MODEL_INPUT_SIZE=224,224
MODEL_COLOR_MODE=rgb
# Use scale_0_1, none, keras_vgg16, or keras_resnet50.
MODEL_PREPROCESS=scale_0_1
# Labels must be in the exact order used during training.
CLASS_NAMES=Normal,Pneumonia
